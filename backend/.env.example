# ============================================================
# ARCADIUM BACKEND - Variables de entorno
# Copiar a .env y completar con valores reales
# ============================================================

# --- App ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Supabase (proyecto Postgres) ---
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres"

# --- Supabase (Auth - validación JWT) ---
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_JWT_SECRET=<jwt-secret-from-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>

# --- PayPal Sandbox ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
